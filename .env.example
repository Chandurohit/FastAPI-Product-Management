# Environment: development or production
ENV=development

# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT configuration
# In production, SECRET_KEY MUST be set to a secure secret. If ENV=production and SECRET_KEY is not set or matches default, the server will refuse to start.
SECRET_KEY=dev_default_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Cookie configuration
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Future Cloudinary configuration (Placeholders)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Future Email configuration (Placeholders)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email_username@gmail.com
EMAIL_PASSWORD=your_email_app_password

# Future Redis configuration (Placeholders)
REDIS_URL=redis://localhost:6379/0
